#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "${ROOT}"

if command -v php >/dev/null 2>&1; then
    PHP_BIN="php"
else
    PHP_BIN="./.tools/bin/php"
fi

git diff --check

find database modules examples -name '*.sql' -print0 \
    | xargs -0 -n1 sh -c 'test -s "$1"' sh

find modules examples/sample_module -mindepth 1 -maxdepth 1 -type d -print0 \
    | xargs -0 -n1 sh -c '
        module_dir="$1"
        test -f "${module_dir}/module.php" || exit 0
        test -f "${module_dir}/install.sql"
        if test -f "${module_dir}/admin-menu.php"; then
            test -f "${module_dir}/paths.php"
        fi
    ' sh

find modules examples/sample_module -mindepth 1 -maxdepth 1 -type d -print0 \
    | xargs -0 -n1 sh -c '
        module_dir="$1"
        admin_menu="${module_dir}/admin-menu.php"
        paths="${module_dir}/paths.php"
        test -f "${admin_menu}" || exit 0

        sed -n "s/.*'\''path'\''[[:space:]]*=>[[:space:]]*'\''\\(\\/admin\\/[^'\'']*\\)'\''.*/\\1/p" "${admin_menu}" \
            | while IFS= read -r path; do
                grep -Eq "'\''GET ${path}'\''[[:space:]]*=>" "${paths}" || {
                    echo "Admin menu path is missing from ${paths}: ${path}" >&2
                    exit 1
                }
            done
    ' sh

echo "toycore non-Docker checks completed."

if [ "${PHP_BIN}" = "./.tools/bin/php" ]; then
    if ! command -v docker >/dev/null 2>&1; then
        echo "PHP or Docker is required for policy checks and PHP lint. Install PHP, Docker, or OrbStack, then rerun ./.tools/bin/check." >&2
        exit 1
    fi

    if ! docker info >/dev/null 2>&1; then
        echo "Docker is not running. Start Docker or OrbStack, or install PHP, then rerun ./.tools/bin/check." >&2
        exit 1
    fi
fi

"${PHP_BIN}" .tools/bin/check-module-index.php
"${PHP_BIN}" .tools/bin/check-retention-targets.php
"${PHP_BIN}" .tools/bin/check-auth-runtime.php
"${PHP_BIN}" .tools/bin/check-runtime-helpers.php
"${PHP_BIN}" .tools/bin/check-member-auth-policy.php

find . \
    -path './.git' -prune -o \
    -path './dist' -prune -o \
    -name '*.php' -print0 \
    | xargs -0 -n1 "${PHP_BIN}" -l

echo "toycore checks completed."
