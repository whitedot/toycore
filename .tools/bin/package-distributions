#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
DIST="${ROOT}/dist"
VERSION="${1:-dev}"
MODULE_REPO_ROOT="${TOYCORE_MODULE_REPO_ROOT:-$(dirname "${ROOT}")}"
DISTRIBUTION_POLICY="${ROOT}/docs/distributions.json"

copy_path() {
    source_path="$1"
    target_root="$2"

    if [ ! -e "${ROOT}/${source_path}" ]; then
        return
    fi

    mkdir -p "${target_root}/$(dirname "${source_path}")"
    cp -R "${ROOT}/${source_path}" "${target_root}/${source_path}"
}

copy_base() {
    target_root="$1"

    mkdir -p "${target_root}"
    for path in \
        README.md \
        index.php \
        assets/toycore.css \
        config/.gitignore \
        core \
        database \
        lang \
        storage/.gitignore \
        docs/deployment-examples.md \
        docs/deployment-protection.md \
        docs/distributions.json \
        docs/install-plan.md \
        docs/module-index.json \
        docs/module-guide.md \
        docs/module-repository-strategy.md \
        docs/release-process.md \
        docs/security-checklist.md \
        docs/shared-hosting-install.md \
        docs/update-plan.md \
        modules/member \
        modules/admin
    do
        copy_path "${path}" "${target_root}"
    done
}

copy_module() {
    target_root="$1"
    module_key="$2"

    if [ -d "${ROOT}/modules/${module_key}" ]; then
        copy_path "modules/${module_key}" "${target_root}"
        return
    fi

    module_repo_key="$(printf '%s' "${module_key}" | tr '_' '-')"
    module_repo_dir="${MODULE_REPO_ROOT}/toycore-module-${module_repo_key}/module"
    if [ ! -d "${module_repo_dir}" ]; then
        echo "module source not found: ${module_key}" >&2
        echo "Expected ${ROOT}/modules/${module_key} or ${module_repo_dir}" >&2
        exit 1
    fi

    mkdir -p "${target_root}/modules/${module_key}"
    cp -R "${module_repo_dir}/." "${target_root}/modules/${module_key}/"
}

copy_modules() {
    target_root="$1"
    shift
    for module_key in "$@"; do
        copy_module "${target_root}" "${module_key}"
    done
}

distribution_modules() {
    distribution_key="$1"

    php -r '
        $path = $argv[1];
        $distributionKey = $argv[2];
        $content = file_get_contents($path);
        $data = is_string($content) ? json_decode($content, true) : null;
        if (!is_array($data) || !isset($data["packages"][$distributionKey]) || !is_array($data["packages"][$distributionKey])) {
            fwrite(STDERR, "Invalid distribution policy: " . $distributionKey . PHP_EOL);
            exit(1);
        }
        echo implode(" ", $data["packages"][$distributionKey]);
    ' "${DISTRIBUTION_POLICY}" "${distribution_key}"
}

distribution_optional_modules() {
    distribution_key="$1"

    php -r '
        $path = $argv[1];
        $distributionKey = $argv[2];
        $content = file_get_contents($path);
        $data = is_string($content) ? json_decode($content, true) : null;
        if (!is_array($data) || !isset($data["packages"][$distributionKey]) || !is_array($data["packages"][$distributionKey])) {
            fwrite(STDERR, "Invalid distribution policy: " . $distributionKey . PHP_EOL);
            exit(1);
        }
        $modules = array_values(array_diff($data["packages"][$distributionKey], ["member", "admin"]));
        echo implode(" ", $modules);
    ' "${DISTRIBUTION_POLICY}" "${distribution_key}"
}

copy_distribution_modules() {
    target_root="$1"
    distribution_key="$2"

    for module_key in $(distribution_optional_modules "${distribution_key}"); do
        copy_module "${target_root}" "${module_key}"
    done
}

module_manifest_entry() {
    module_root="$1"
    module_key="$2"

    if [ ! -f "${module_root}/module.php" ]; then
        printf '{"module_key": "%s", "version": "", "min_toycore_version": "", "module_contract": ""}' "${module_key}"
        return
    fi

    php "${ROOT}/.tools/bin/distribution-manifest-entry.php" "${module_key}" "${module_root}"
}

write_manifest() {
    package_name="$1"
    package_root="$2"
    shift 2

    manifest="${package_root}/distribution-manifest.json"
    {
        printf '{\n'
        printf '  "package": "%s",\n' "${package_name}"
        printf '  "version": "%s",\n' "${VERSION}"
        printf '  "modules": [\n'
        first=1
        for module_key in "$@"; do
            if [ "${first}" -eq 0 ]; then
                printf ',\n'
            fi
            first=0
            printf '    %s' "$(module_manifest_entry "${package_root}/modules/${module_key}" "${module_key}")"
        done
        printf '\n  ]\n'
        printf '}\n'
    } > "${manifest}"
}

make_zip() {
    package_name="$1"
    package_root="$2"

    if command -v zip >/dev/null 2>&1; then
        (
            cd "${DIST}"
            rm -f "${package_name}-${VERSION}.zip"
            zip -qr "${package_name}-${VERSION}.zip" "${package_name}"
        )
    fi
}

rm -rf "${DIST}"
mkdir -p "${DIST}"

minimal_root="${DIST}/toycore-minimal"
standard_root="${DIST}/toycore-standard"
ops_root="${DIST}/toycore-ops"

copy_base "${minimal_root}"
write_manifest toycore-minimal "${minimal_root}" $(distribution_modules minimal)

copy_base "${standard_root}"
copy_distribution_modules "${standard_root}" standard
write_manifest toycore-standard "${standard_root}" $(distribution_modules standard)

copy_base "${ops_root}"
copy_distribution_modules "${ops_root}" ops
write_manifest toycore-ops "${ops_root}" $(distribution_modules ops)

make_zip toycore-minimal "${minimal_root}"
make_zip toycore-standard "${standard_root}"
make_zip toycore-ops "${ops_root}"

echo "Created distribution directories under ${DIST}"
if command -v zip >/dev/null 2>&1; then
    echo "Created zip packages for version ${VERSION}"
else
    echo "zip command not found; directories were created without zip packages"
fi
