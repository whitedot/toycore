#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
DIST="${ROOT}/dist"
VERSION="${1:-dev}"
MODULE_REPO_ROOT="${TOYCORE_MODULE_REPO_ROOT:-$(dirname "${ROOT}")}"

copy_path() {
    source_path="$1"
    target_root="$2"

    if [ ! -e "${ROOT}/${source_path}" ]; then
        return
    fi

    mkdir -p "${target_root}/$(dirname "${source_path}")"
    cp -R "${ROOT}/${source_path}" "${target_root}/${source_path}"
}

copy_base() {
    target_root="$1"

    mkdir -p "${target_root}"
    for path in \
        README.md \
        index.php \
        assets/toycore.css \
        config/.gitignore \
        core \
        database \
        lang \
        storage/.gitignore \
        docs/deployment-examples.md \
        docs/deployment-protection.md \
        docs/install-plan.md \
        docs/module-index.json \
        docs/module-guide.md \
        docs/module-repository-strategy.md \
        docs/release-process.md \
        docs/security-checklist.md \
        docs/shared-hosting-install.md \
        docs/update-plan.md \
        modules/member \
        modules/admin
    do
        copy_path "${path}" "${target_root}"
    done
}

copy_module() {
    target_root="$1"
    module_key="$2"

    if [ -d "${ROOT}/modules/${module_key}" ]; then
        copy_path "modules/${module_key}" "${target_root}"
        return
    fi

    module_repo_key="$(printf '%s' "${module_key}" | tr '_' '-')"
    module_repo_dir="${MODULE_REPO_ROOT}/toycore-module-${module_repo_key}/module"
    if [ ! -d "${module_repo_dir}" ]; then
        echo "module source not found: ${module_key}" >&2
        echo "Expected ${ROOT}/modules/${module_key} or ${module_repo_dir}" >&2
        exit 1
    fi

    mkdir -p "${target_root}/modules/${module_key}"
    cp -R "${module_repo_dir}/." "${target_root}/modules/${module_key}/"
}

copy_modules() {
    target_root="$1"
    shift
    for module_key in "$@"; do
        copy_module "${target_root}" "${module_key}"
    done
}

module_version() {
    module_root="$1"

    if [ ! -f "${module_root}/module.php" ]; then
        printf ''
        return
    fi

    sed -n "s/.*'version'[[:space:]]*=>[[:space:]]*'\\([^']*\\)'.*/\\1/p" "${module_root}/module.php" | sed -n '1p'
}

write_manifest() {
    package_name="$1"
    package_root="$2"
    shift 2

    manifest="${package_root}/distribution-manifest.json"
    {
        printf '{\n'
        printf '  "package": "%s",\n' "${package_name}"
        printf '  "version": "%s",\n' "${VERSION}"
        printf '  "modules": [\n'
        first=1
        for module_key in member admin "$@"; do
            version="$(module_version "${package_root}/modules/${module_key}")"
            if [ "${first}" -eq 0 ]; then
                printf ',\n'
            fi
            first=0
            printf '    {"module_key": "%s", "version": "%s"}' "${module_key}" "${version}"
        done
        printf '\n  ]\n'
        printf '}\n'
    } > "${manifest}"
}

make_zip() {
    package_name="$1"
    package_root="$2"

    if command -v zip >/dev/null 2>&1; then
        (
            cd "${DIST}"
            rm -f "${package_name}-${VERSION}.zip"
            zip -qr "${package_name}-${VERSION}.zip" "${package_name}"
        )
    fi
}

rm -rf "${DIST}"
mkdir -p "${DIST}"

minimal_root="${DIST}/toycore-minimal"
standard_root="${DIST}/toycore-standard"
ops_root="${DIST}/toycore-ops"

copy_base "${minimal_root}"
write_manifest toycore-minimal "${minimal_root}"

copy_base "${standard_root}"
copy_modules "${standard_root}" seo popup_layer point deposit reward
write_manifest toycore-standard "${standard_root}" seo popup_layer point deposit reward

copy_base "${ops_root}"
copy_modules "${ops_root}" seo popup_layer point deposit reward site_menu banner notification
write_manifest toycore-ops "${ops_root}" seo popup_layer point deposit reward site_menu banner notification

make_zip toycore-minimal "${minimal_root}"
make_zip toycore-standard "${standard_root}"
make_zip toycore-ops "${ops_root}"

echo "Created distribution directories under ${DIST}"
if command -v zip >/dev/null 2>&1; then
    echo "Created zip packages for version ${VERSION}"
else
    echo "zip command not found; directories were created without zip packages"
fi
