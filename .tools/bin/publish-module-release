#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
VERSION="${1:-}"
RELEASE_REPO="${2:-whitedot/toycore-module-releases}"
MODULE_REPO_ROOT="${3:-${TOYCORE_MODULE_REPO_ROOT:-$(dirname "${ROOT}")}}"

if ! printf '%s' "${VERSION}" | grep -Eq '^[0-9]{4}\.[0-9]{2}\.[0-9]{3}$'; then
    echo "Usage: ./.tools/bin/publish-module-release YYYY.MM.NNN [owner/repo] [module-repo-root]" >&2
    exit 1
fi

if ! printf '%s' "${RELEASE_REPO}" | grep -Eq '^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$'; then
    echo "GitHub release repository must use owner/repo format." >&2
    exit 1
fi

if ! command -v php >/dev/null 2>&1; then
    echo "php is required to read docs/module-index.json." >&2
    exit 1
fi

TAG="v${VERSION}"
RELEASE_BASE_URL="https://github.com/${RELEASE_REPO}/releases/download/${TAG}"
MODULE_DIST="${ROOT}/dist/modules"
INDEX_PATH="${ROOT}/docs/module-index.json"

module_keys="$(
    php -r '
        $index = json_decode(file_get_contents($argv[1]), true);
        if (!is_array($index) || !is_array($index["modules"] ?? null)) {
            fwrite(STDERR, "module index JSON is invalid.\n");
            exit(1);
        }

        foreach ($index["modules"] as $module) {
            $moduleKey = (string) ($module["module_key"] ?? "");
            if (preg_match("/\A[a-z0-9_]+\z/", $moduleKey) === 1) {
                echo $moduleKey, PHP_EOL;
            }
        }
    ' "${INDEX_PATH}"
)"

rm -rf "${MODULE_DIST}"
mkdir -p "${MODULE_DIST}"

for module_key in ${module_keys}; do
    module_repo_key="$(printf '%s' "${module_key}" | tr '_' '-')"
    module_repo="${MODULE_REPO_ROOT}/toycore-module-${module_repo_key}"
    package_script="${module_repo}/.tools/bin/package-module"
    zip_name="${module_key}-${VERSION}.zip"

    if [ ! -d "${module_repo}" ]; then
        echo "module repository not found: ${module_repo}" >&2
        exit 1
    fi

    if [ ! -x "${package_script}" ]; then
        echo "module package script is missing or not executable: ${package_script}" >&2
        exit 1
    fi

    (
        cd "${module_repo}"
        "${package_script}" "${VERSION}"
    )

    zip_path="$(find "${module_repo}" -path "${module_repo}/.git" -prune -o -type f -name "${zip_name}" -print | sed -n '1p')"
    if [ "${zip_path}" = "" ]; then
        echo "module zip was not created: ${zip_name}" >&2
        exit 1
    fi

    cp "${zip_path}" "${MODULE_DIST}/${zip_name}"
done

if [ "${TOYCORE_UPDATE_REPOSITORY_REFS:-0}" = "1" ]; then
    "${ROOT}/.tools/bin/update-module-index" "${VERSION}" "${RELEASE_BASE_URL}" "${MODULE_DIST}" --repository-refs "${MODULE_REPO_ROOT}"
else
    "${ROOT}/.tools/bin/update-module-index" "${VERSION}" "${RELEASE_BASE_URL}" "${MODULE_DIST}"
fi

if command -v gh >/dev/null 2>&1; then
    if gh release view "${TAG}" --repo "${RELEASE_REPO}" >/dev/null 2>&1; then
        echo "Using existing GitHub release ${RELEASE_REPO} ${TAG}"
    else
        gh release create "${TAG}" --repo "${RELEASE_REPO}" --title "${TAG}" --notes "Toycore official module zips for ${VERSION}"
    fi

    gh release upload "${TAG}" "${MODULE_DIST}"/*.zip --repo "${RELEASE_REPO}" --clobber
    echo "Uploaded module zips to ${RELEASE_BASE_URL}"
else
    echo "gh command not found; upload the module zips manually or run:"
    echo "gh release create ${TAG} ${MODULE_DIST}/*.zip --repo ${RELEASE_REPO} --title ${TAG} --notes \"Toycore official module zips for ${VERSION}\""
fi

echo "Module release assets are in ${MODULE_DIST}"
